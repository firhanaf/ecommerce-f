# App
APP_PORT=8080
APP_ENV=development

# Database (AWS RDS atau local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=ecommerce_db
DB_SSLMODE=disable  # production: require

# JWT
JWT_SECRET=ganti-dengan-random-string-minimal-32-karakter
JWT_ACCESS_TTL=60    # menit
JWT_REFRESH_TTL=7    # hari

# AWS
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx  # SB- prefix = sandbox
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_PRODUCTION=false

# Fonnte (WhatsApp OTP + Notifikasi Order)
# Daftar di https://fonnte.com — ada free tier 1000 pesan/bulan
FONNTE_TOKEN=your-fonnte-token
FONNTE_ADMIN_PHONE=628123456789  # nomor WA admin untuk notifikasi pesanan baru
